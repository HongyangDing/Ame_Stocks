  "grain": "One immutable approved decision version for one exact provider/ticker/legal-event transition series.",
  "partition_by": [],
  "primary_key": [
    "asset_transition_id"
  ],
  "qa_rules": [
    {
      "check_id": "schema_exact",
      "description": "Fields, order, Arrow types and nullability must exactly match.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "primary_key_null_or_duplicate_rows",
      "description": "Transition IDs must be non-null and unique.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "append_only_version_chain_invalid_rows",
      "description": "Versions must be contiguous and reference the immediate predecessor.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "decision_id_recomputation_mismatch_rows",
      "description": "Subject, series, source-set, asset and transition IDs must reproduce.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "provider_scope_invalid_rows",
      "description": "Scope must remain exact massive/stocks/us and case-sensitive ticker.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "transition_boundary_invalid_rows",
      "description": "Legal and predecessor/successor session boundaries must be ordered and evidence-backed.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "self_transition_rows",
      "description": "A confirmed transition cannot map an asset to itself.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "transition_cycle_rows",
      "description": "Effective confirmed transition relations must form an acyclic graph.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "boundary_source_scope_invalid_rows",
      "description": "Every exact boundary source record and release binding must reconcile.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "external_evidence_manifest_binding_invalid_rows",
      "description": "SEC, issuer and OpenFIGI bytes, claims, timestamps and SHAs must replay.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "approval_chain_invalid_rows",
      "description": "Decision plan, request event and row receipt must bind the exact transition.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "availability_recomputation_mismatch_rows",
      "description": "Availability must be max(candidate, evidence, approval), never event date.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "unapproved_asset_transition_rows",
      "description": "Only approved transition decisions may enter a release.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "asset_transition_used_as_identity_override_rows",
      "description": "A relation cannot execute a Composite or Share Class override.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "asset_transition_return_stitching_rows",
      "description": "A relation cannot stitch returns without future entitlement-aware accounting.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "asset_transition_membership_mutation_rows",
      "description": "A relation cannot alter active/inactive membership.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "asset_transition_tradability_rows",
      "description": "A relation alone cannot set final tradability.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "identity_quality_forced_liquidation_signal_rows",
      "description": "A transition relation cannot trigger liquidation.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "temporary_security_merged_into_ordinary_asset_rows",
      "description": "A temporary ex-distribution security may not be merged into its ordinary ticker asset.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "outcome_or_backtest_evidence_rows",
      "description": "Returns, factors and backtests are prohibited evidence.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    }
  ],
