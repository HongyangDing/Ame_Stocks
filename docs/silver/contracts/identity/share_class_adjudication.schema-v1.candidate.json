  "grain": "One immutable approved decision version for one provider/market/locale/ticker/observed Composite/observed Share Class subject over one exact S4 source-record scope.",
  "partition_by": [],
  "primary_key": [
    "share_class_adjudication_id"
  ],
  "qa_rules": [
    {
      "check_id": "schema_exact",
      "description": "Fields, order, Arrow types and nullability must exactly match.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "primary_key_null_or_duplicate_rows",
      "description": "Decision IDs must be non-null and unique.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "append_only_version_chain_invalid_rows",
      "description": "Versions must be contiguous and reference the immediate predecessor.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "decision_id_recomputation_mismatch_rows",
      "description": "Subject, series, source-set and decision IDs must reproduce.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "provider_scope_invalid_rows",
      "description": "Scope must remain exact massive/stocks/us and case-sensitive ticker.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "exact_source_scope_invalid_rows",
      "description": "Composite, Share Class, interval, release and every source record must reconcile.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "unique_canonical_composite_precondition_invalid_rows",
      "description": "A Share Class decision may apply only after one canonical Composite is uniquely resolved.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "canonical_share_class_target_evidence_invalid_rows",
      "description": "The canonical Share Class target must have independent immutable evidence.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "approval_chain_invalid_rows",
      "description": "Decision plan, request event and row receipt must bind the exact decision.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "availability_recomputation_mismatch_rows",
      "description": "Availability must be max(candidate, evidence, approval).",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "overlapping_share_class_adjudication_rows",
      "description": "One source row may match at most one effective Share Class decision.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "unapproved_share_class_override_rows",
      "description": "Only approved decision rows may enter a release.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "share_class_adjudication_changed_composite_rows",
      "description": "A Share Class decision cannot change canonical Composite identity.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "share_class_adjudication_changed_asset_id_rows",
      "description": "A Share Class decision cannot create or change asset_id.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "share_class_adjudication_changed_issuer_rows",
      "description": "A Share Class decision cannot create, merge or change issuer identity.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "share_class_adjudication_membership_mutation_rows",
      "description": "A Share Class decision cannot alter membership or active status.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "share_class_adjudication_tradability_rows",
      "description": "A Share Class decision alone cannot set final tradability.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "observed_hierarchy_lineage_mutated_rows",
      "description": "Observed Share Class and source lineage must remain unchanged.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "identity_quality_forced_liquidation_signal_rows",
      "description": "A hierarchy correction cannot trigger liquidation.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "outcome_or_backtest_evidence_rows",
      "description": "Returns, factors and backtests are prohibited evidence.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_share_class_adjudication_collision_rows",
      "description": "Report raw multi-decision matches with reason counts and examples.",
      "failure_status": "warning",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "high"
    },
    {
      "check_id": "multi_share_class_adjudication_collision_eligible_rows",
      "description": "A hierarchy collision must not remain identity eligible.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_share_class_adjudication_collision_resolved_rows",
      "description": "A hierarchy collision must not auto-resolve.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_share_class_adjudication_collision_alias_rows",
      "description": "A hierarchy collision must not emit an alias.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    }
  ],
