  "contract_id": "a090c4ed150b2f59c38b4f01791f70ce655d44e9c3576bd0a13ac7fd9ba32bc5",
  "contract_schema_version": 1,
  "description": "Append-only, exact-source-row same-market Composite corrections that are valid only after an independently approved genuine asset transition. Observed lineage is immutable.",
  "domain": "identity",
  "grain": "One immutable approved decision version for one provider/market/locale/ticker/observed Composite and asset-transition series over one exact S4 source-record scope.",
  "partition_by": [],
  "primary_key": [
    "provider_composite_override_id"
  ],
  "qa_rules": [
    {
      "check_id": "schema_exact",
      "description": "Fields, order, Arrow types and nullability must exactly match.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "primary_key_null_or_duplicate_rows",
      "description": "Decision IDs must be non-null and unique.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "append_only_version_chain_invalid_rows",
      "description": "Versions must be contiguous and reference the immediate predecessor.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "decision_id_recomputation_mismatch_rows",
      "description": "Subject, series, source-set and decision IDs must reproduce.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "provider_scope_invalid_rows",
      "description": "Scope must remain exact massive/stocks/us and case-sensitive ticker.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "same_market_target_invalid_rows",
      "description": "Confirmed observed/canonical Composite market codes must match.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "exact_source_scope_invalid_rows",
      "description": "Interval, release and every exact source record must reconcile.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "asset_transition_binding_invalid_rows",
      "description": "Every confirmed correction must bind one approved genuine transition available by cutoff.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "canonical_target_evidence_invalid_rows",
      "description": "The successor Composite must have an immutable independent authority assertion.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "approval_chain_invalid_rows",
      "description": "Decision plan, request event and row receipt must bind the exact decision.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "availability_recomputation_mismatch_rows",
      "description": "Availability must be max(candidate, transition, evidence, approval).",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "overlapping_provider_override_rows",
      "description": "One source row may match at most one effective provider override subject.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "unapproved_provider_composite_override_rows",
      "description": "Only approved decision rows may enter a release.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "observed_identity_lineage_mutated_rows",
      "description": "Observed Composite and source lineage must remain byte-for-byte attributable to S4.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "identity_quality_membership_mutation_rows",
      "description": "A correction cannot alter membership or active status.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "identity_quality_forced_liquidation_signal_rows",
      "description": "A correction cannot trigger liquidation.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "outcome_or_backtest_evidence_rows",
      "description": "Returns, factors and backtests are prohibited evidence.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_registry_composite_override_collision_rows",
      "description": "Report every source row matched by multiple Composite correction registries with reason counts and examples.",
      "failure_status": "warning",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "high"
    },
    {
      "check_id": "multi_registry_composite_override_collision_eligible_rows",
      "description": "A collision row must never remain identity eligible.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_registry_composite_override_collision_resolved_rows",
      "description": "A collision row must never be resolved automatically.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    },
    {
      "check_id": "multi_registry_composite_override_collision_alias_rows",
      "description": "A collision row must never emit an alias.",
      "failure_status": "failed",
      "limit": 0.0,
      "metric": "numerator",
      "operator": "eq",
      "severity": "critical"
    }
  ],
  "schema_version": 1,
  "sort_by": [
    "observed_ticker",
    "valid_from_session",
    "decision_version"
  ],
  "source_datasets": [
    "identity_exact_group_history_review_slot",
